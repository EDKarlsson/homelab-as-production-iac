#cloud-config
# K3s Agent Node Configuration Template  
# Norse-themed Asgard K3s Cluster - Worker Node

hostname: ${hostname}
fqdn: ${hostname}.homelab.local

users:
  - name: ${username}
    groups: [adm, sudo]
    lock_passwd: false
    sudo: ALL=(ALL) NOPASSWD:ALL
    shell: /bin/bash
    ssh_authorized_keys:
      - ${ssh_public_key}

# APT configuration — optionally route through Nexus proxy cache
# Prerequisite: apt-ubuntu and apt-ubuntu-security proxy repos must exist
# in Nexus before provisioning VMs with this enabled.
# Run scripts/nexus/configure-proxy-repos.sh first.
%{ if nexus_apt_mirror_url != "" ~}
apt:
  primary:
    - arches: [amd64, i386]
      uri: ${nexus_apt_mirror_url}/repository/apt-ubuntu/
  security:
    - arches: [amd64, i386]
      uri: ${nexus_apt_mirror_url}/repository/apt-ubuntu-security/
%{ endif ~}

# Package updates and installations
package_update: true
package_upgrade: true

packages:
  - curl
  - wget
  - jq
  - htop
  - net-tools
  - unzip
  - git
  - nfs-common
  - qemu-guest-agent

runcmd:
  # Disable swap permanently
  - swapoff -a
  - sed -i '/ swap / s/^\(.*\)$/#\1/g' /etc/fstab
  
  # Configure kernel modules for Kubernetes
  - modprobe br_netfilter
  - modprobe ip_vs
  - modprobe ip_vs_rr
  - modprobe ip_vs_wrr
  - modprobe ip_vs_sh
  - modprobe nf_conntrack
  
  # Create modules-load configuration
  - |
    cat > /etc/modules-load.d/k3s.conf << EOF
    br_netfilter
    ip_vs
    ip_vs_rr
    ip_vs_wrr
    ip_vs_sh
    nf_conntrack
    EOF
  
  # Configure sysctl for Kubernetes
  - |
    cat > /etc/sysctl.d/k3s.conf << EOF
    net.bridge.bridge-nf-call-ip6tables = 1
    net.bridge.bridge-nf-call-iptables = 1
    net.ipv4.ip_forward = 1
    EOF
  - sysctl --system
  
  # Create K3s configuration directory
  - mkdir -p /etc/rancher/k3s
  
  # Configure K3s agent
  - |
    cat > /etc/rancher/k3s/config.yaml << EOF
    server: ${server_url}
    token: ${k3s_token}
    node-name: ${hostname}
    protect-kernel-defaults: false
    EOF
  
  # Wait for server to be available
  - |
    echo "Waiting for K3s server to be available..."
    until curl -k -s ${server_url}/readyz >/dev/null 2>&1; do
      echo "Server not ready, waiting..."
      sleep 10
    done
    echo "K3s server is available!"
  
  # Download and install K3s agent
  - curl -sfL https://get.k3s.io | INSTALL_K3S_VERSION=${k3s_version} K3S_URL=${server_url} K3S_TOKEN=${k3s_token} sh -s - agent
  
  # Wait for K3s agent to be ready
  - |
    until systemctl is-active --quiet k3s-agent; do
      echo "Waiting for K3s agent to start..."
      sleep 5
    done
  
  # Set up kubectl for default user (read-only access)
  - |
    # Wait for kubeconfig to be available from server
    sleep 30
    mkdir -p /home/${username}/.kube
    
    # Copy kubeconfig from server (requires network access)
    until curl -k -s ${server_url}/cacerts >/dev/null 2>&1; do
      echo "Waiting for server CA certs..."
      sleep 5
    done
    
    # Create a basic kubeconfig that points to the server
    cat > /home/${username}/.kube/config << EOF
    apiVersion: v1
    kind: Config
    clusters:
    - cluster:
        server: ${server_url}
        insecure-skip-tls-verify: true
      name: default
    contexts:
    - context:
        cluster: default
        user: default
      name: default
    current-context: default
    users:
    - name: default
      user:
        token: ${k3s_token}
    EOF
    
    chown -R ${username}:${username} /home/${username}/.kube
    chmod 600 /home/${username}/.kube/config
  
  # Create kubectl alias
  - echo 'alias k=kubectl' >> /home/${username}/.bashrc
  - echo 'complete -F __start_kubectl k' >> /home/${username}/.bashrc
  
  # Install useful container tools
  - |
    # Install crictl for container runtime debugging
    wget -q https://github.com/kubernetes-sigs/cri-tools/releases/download/v1.32.0/crictl-v1.32.0-linux-amd64.tar.gz
    tar zxvf crictl-v1.32.0-linux-amd64.tar.gz -C /usr/local/bin
    rm -f crictl-v1.32.0-linux-amd64.tar.gz
    
    # Configure crictl
    cat > /etc/crictl.yaml << EOF
    runtime-endpoint: unix:///run/k3s/containerd/containerd.sock
    image-endpoint: unix:///run/k3s/containerd/containerd.sock
    timeout: 2
    debug: false
    pull-image-on-create: false
    EOF

write_files:
  - path: /etc/systemd/system/k3s-agent-wait.service
    content: |
      [Unit]
      Description=Wait for K3s Agent to be ready
      After=k3s-agent.service
      Requires=k3s-agent.service
      
      [Service]
      Type=oneshot
      ExecStart=/bin/bash -c 'until systemctl is-active k3s-agent; do sleep 5; done'
      RemainAfterExit=yes
      
      [Install]
      WantedBy=multi-user.target
    permissions: '0644'

  - path: /etc/logrotate.d/k3s
    content: |
      /var/log/k3s.log {
        daily
        missingok
        rotate 7
        compress
        delaycompress
        notifempty
        copytruncate
      }
    permissions: '0644'

  - path: /home/${username}/.bashrc.d/k3s-aliases
    defer: true
    content: |
      # K3s and Kubernetes aliases
      alias k=kubectl
      alias kgp='kubectl get pods'
      alias kgs='kubectl get svc' 
      alias kgn='kubectl get nodes'
      alias kdp='kubectl describe pod'
      alias kds='kubectl describe svc'
      alias kdn='kubectl describe node'
      alias kl='kubectl logs'
      alias kpf='kubectl port-forward'
      
      # Container runtime aliases
      alias crictl='crictl'
      alias ctr='k3s ctr'
    permissions: '0644'
    owner: ${username}:${username}

final_message: |
  K3s Agent Node ${hostname} installation completed!
  
  Node Information:
  - Node Name: ${hostname}
  - Role: Worker Node (Agent)
  - Server URL: ${server_url}
  
  Access:
  - SSH: ssh ${username}@$(hostname -I | awk '{print $1}')
  - kubectl: Basic access configured for user ${username}
  
  Useful Commands:
  - Check node status: kubectl get nodes
  - View pods on this node: kubectl get pods --field-selector spec.nodeName=${hostname}
  - Container runtime: crictl ps
  - K3s logs: journalctl -u k3s-agent -f
  
  Next Steps:
  - Verify node joined cluster: kubectl get nodes
  - Deploy workloads to test functionality
  - Configure monitoring and logging agents
