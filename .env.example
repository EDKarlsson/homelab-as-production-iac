# Homelab IAC Environment Variables
#
# Copy to .env.d/terraform.env and fill in values.
# See configs/final.env for the op:// reference version (use with `op run`).

# --- 1Password Connect (required for Terraform) ---
# Proxmox credentials are read from 1Password at plan/apply time.
TF_VAR_op_connect_host="http://10.0.0.72:8080"
TF_VAR_op_connect_token="<your-connect-jwt-here>"

# --- Terraform Remote State Backend (PostgreSQL) ---
# Required after migrating state to PostgreSQL (see docs/guides/terraform-remote-state.md)
# PG_CONN_STR="postgres://terraform:<password>@10.0.0.45:5432/terraform_state"

# --- Non-secret defaults ---
TF_VAR_proxmox_ve_datastore_id="local-lvm"
TF_VAR_proxmox_ve_node_name="node-02"

# --- SSH (1Password agent) ---
SSH_AUTH_SOCK="~/.1password/agent.sock"

# --- Ansible ---
ANSIBLE_CONFIG="/path/to/homelab-iac/ansible.cfg"

# --- IMPORTANT ---
# Do NOT set PROXMOX_VE_* env vars (PROXMOX_VE_API_TOKEN, PROXMOX_VE_USERNAME, etc.)
# The bpg/proxmox provider reads these automatically and they OVERRIDE the provider block.
# All Proxmox auth is handled via 1Password Connect → provider "proxmox" {} block.
