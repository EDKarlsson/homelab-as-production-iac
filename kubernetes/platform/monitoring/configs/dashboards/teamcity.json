        "defaults": {
          "unit": "bytes",
          "custom": {
            "lineInterpolation": "linear",
            "fillOpacity": 10
          }
        },
        "overrides": []
      }
    },
    {
      "id": 11,
      "type": "row",
      "title": "Storage",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 18
      },
      "collapsed": false,
      "panels": []
    },
    {
