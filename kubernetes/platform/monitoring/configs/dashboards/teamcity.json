      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by(pod) (container_memory_working_set_bytes{namespace=\"teamcity\",pod=~\"teamcity-agent-.*\",container!=\"\",image!=\"\"})",
          "legendFormat": "{{pod}}",
          "refId": "A"
        }
      ],
      "options": {
        "tooltip": {
          "mode": "multi"
        },
        "legend": {
