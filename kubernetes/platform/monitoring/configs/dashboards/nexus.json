      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_threads_current{namespace=\"nexus\"}",
          "legendFormat": "Current",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "jvm_threads_daemon{namespace=\"nexus\"}",
          "legendFormat": "Daemon",
          "refId": "B"
