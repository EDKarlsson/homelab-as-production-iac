          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(jvm_memory_bytes_used{namespace=\"nexus\", area=\"heap\"}) / sum(jvm_memory_bytes_max{namespace=\"nexus\", area=\"heap\"})",
          "legendFormat": "Heap %",
          "refId": "A"
        }
      ]
